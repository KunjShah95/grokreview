// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Test {
  id    String @id @default(cuid())
  title String
}

model User {
  id                     String    @id @default(cuid())
  name                   String
  email                  String
  emailVerified          Boolean   @default(false)
  image                  String?
  plan                   String    @default("free") // free | pro
  razorpaySubscriptionId String?
  subscriptionStatus     String?   // active | canceled | trialing
  subscriptionRenewsAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions            Session[]
  accounts            Account[]
  githubInstallation  GithubInstallation?
  usageAlerts         UsageAlert[]
  chatSessions        ChatSession[]

  @@unique([email])
  @@map("user")
}

model GithubInstallation {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  installationId  Int // GitHub's numeric installation id
  accountLogin    String?
  accountType     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("github_installation")
}

model PullRequest {
  id               String   @id @default(cuid())
  installationId   Int
  repoFullName     String   // e.g. "owner/repo"
  prNumber         Int
  title            String
  authorLogin      String?
  headSha          String   // latest commit on the PR branch
  baseBranch       String
  status           String   @default("pending") // pending | processing | reviewed | rate_limited
  model            String?  // AI model used for review (e.g. "groq/llama3-70b-8192")
  reviewComment    String?  // AI-generated markdown saved after review completes
  reviewedAt       DateTime?
  complexityScore  Int?     // estimated review complexity, 1-10

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  securityFindings SecurityFinding[]
  generatedTests   GeneratedTest[]

  @@unique([repoFullName, prNumber])
  @@map("pull_request")
}

model SecurityFinding {
  id            String      @id @default(cuid())
  pullRequestId String
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  filePath      String
  line          Int?
  severity      String      // critical | high | medium | low | info
  category      String      // secret | sql-injection | xss | ssrf | dependency | insecure-config
  message       String
  suggestion    String?
  resolved      Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@index([pullRequestId])
  @@map("security_finding")
}

model GeneratedTest {
  id            String      @id @default(cuid())
  pullRequestId String
  pullRequest   PullRequest @relation(fields: [pullRequestId], references: [id], onDelete: Cascade)
  filePath      String      // source file the test targets
  testFilePath  String      // suggested path for the generated test
  framework     String      // vitest | jest | pytest | go-test | ...
  content       String      // generated test code
  createdAt     DateTime    @default(now())

  @@index([pullRequestId])
  @@map("generated_test")
}

model ChatSession {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  repoFullName String
  title        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     ChatMessage[]

  @@index([userId, repoFullName])
  @@map("chat_session")
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  role          String      // user | assistant
  content       String
  citedChunks   Json?       // source file/line citations returned with the answer
  createdAt     DateTime    @default(now())

  @@index([chatSessionId])
  @@map("chat_message")
}

model CodeHealthSnapshot {
  id              String   @id @default(cuid())
  repoFullName    String
  complexityAvg   Float    // average estimated cyclomatic complexity across synced files
  hotspotCount    Int      // files flagged as high churn + high complexity
  hotspots        Json?    // top hotspot files (filePath, complexity, lines) for this snapshot
  securityDebt    Int      // open (unresolved) SecurityFinding count
  testCoverageEst Float?   // heuristic estimate, not measured
  filesAnalyzed   Int      @default(0)
  computedAt      DateTime @default(now())

  @@index([repoFullName, computedAt])
  @@map("code_health_snapshot")
}

model RepoSync {
  id              String   @id @default(cuid())
  installationId  Int
  repoFullName    String
  branch          String
  status          String   @default("pending") // pending | syncing | synced | failed
  chunkCount      Int      @default(0)
  syncedAt        DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([repoFullName])
  @@map("repo_sync")
}

model Session {
  id         String    @id @default(cuid())
  expiresAt  DateTime
  token      String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  ipAddress  String?
  userAgent  String?
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("account")
}

model UsageAlert {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  threshold      Int      // 80 or 100 (percentage)
  sentAt         DateTime @default(now())
  billingMonth   String   // e.g. "2026-07" — prevents re-sending within same cycle
  createdAt      DateTime @default(now())

  @@unique([userId, billingMonth, threshold])
  @@map("usage_alert")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([identifier])
  @@map("verification")
}
