{
  "name": "grokreview",
  "version": "0.1.0",
  "description": "GrokReview CLI - AI-powered GitHub PR reviews, security scans, and test generation from your terminal. Bring your own model: Groq, Mistral, HuggingFace, Gemini, OpenRouter, or local Ollama.",
  "type": "module",
  "bin": {
    "grokreview": "dist/index.js",
    "pr-review": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.93",
    "@ai-sdk/groq": "^3.0.52",
    "@ai-sdk/huggingface": "^1.0.62",
    "@ai-sdk/mistral": "^3.0.49",
    "@ai-sdk/openai": "^3.0.85",
    "ai": "^6.0.205",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "octokit": "^5.0.5",
    "ora": "^8.0.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "grokreview",
    "pr-review",
    "code-review",
    "github",
    "ai",
    "ai-code-review",
    "pull-request",
    "groq",
    "mistral",
    "gemini",
    "ollama",
    "openrouter",
    "security-scanner",
    "test-generation",
    "cli"
  ],
  "author": "Kunj Shah",
  "license": "MIT",
  "homepage": "https://github.com/KunjShah95/grokreview#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KunjShah95/grokreview.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/KunjShah95/grokreview/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
