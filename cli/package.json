{
  "name": "grokreview-cli",
  "version": "0.1.0",
  "description": "GrokReview CLI - AI-powered GitHub PR reviews. Supports Groq, Mistral, HuggingFace, OpenRouter, and local Ollama models.",
  "type": "module",
  "bin": {
    "pr-review": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "prepublishOnly": "npm run build",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "octokit": "^5.0.5",
    "ai": "^6.0.205",
    "@ai-sdk/groq": "^1.0.0",
    "@ai-sdk/mistral": "^1.0.0",
    "@ai-sdk/huggingface": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "@types/node": "^20.14.0"
  },
  "keywords": [
    "pr-review",
    "code-review",
    "github",
    "ai",
    "groq",
    "ollama",
    "cli"
  ]
}
