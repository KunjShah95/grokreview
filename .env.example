# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5438/myApp"

# Better-Auth (GitHub OAuth)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# GitHub App (for Octokit — create at github.com/settings/apps)
GITHUB_APP_ID=""
GITHUB_APP_PRIVATE_KEY=""
GITHUB_WEBHOOK_SECRET=""
GITHUB_APP_SLUG="grokreview"

# OpenRouter (AI — gateway to 200+ models)
OPENROUTER_API_KEY=""

# Groq (AI — extremely fast, free tier at console.groq.com)
GROQ_API_KEY=""

# Mistral AI
MISTRAL_API_KEY=""

# HuggingFace (free inference API)
HUGGINGFACE_API_KEY=""

# Gemini (Google AI Studio — free tier at aistudio.google.com/apikey)
GEMINI_API_KEY=""

# Ollama (LOCAL models — no key needed, requires localhost:11434)
OLLAMA_BASE_URL="http://localhost:11434"

# Pinecone (Vector Database for codebase-aware reviews)
PINECONE_API_KEY=""
PINECONE_INDEX=""

# Razorpay (Payments — India only, optional for Pro plan)
NEXT_PUBLIC_RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_PLAN_ID=""

# PR Reviewer (API key for CI-based reviews)
PR_REVIEWER_API_KEY=""
